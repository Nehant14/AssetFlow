// backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- ENUMS ---
enum Role {
  Admin
  Asset_Manager
  Department_Head
  Employee
}

enum UserStatus {
  Active
  Inactive
}

enum DepartmentStatus {
  Active
  Inactive
}

enum AssetStatus {
  Available
  Allocated
  Reserved
  Under_Maintenance
  Lost
  Retired
  Disposed
}

enum BookingStatus {
  Upcoming
  Ongoing
  Completed
  Cancelled
}

enum MaintenanceStatus {
  Pending
  Approved
  Rejected
  In_Progress
  Resolved
}

// --- MODELS ---

model User {
  id             String     @id @default(uuid())
  name           String
  email          String     @unique
  password       String
  role           Role       @default(Employee)
  status         UserStatus @default(Active)
  
  departmentId   String?
  department     Department? @relation("EmployeeDepartment", fields: [departmentId], references: [id])
  
  managedDept    Department? @relation("DepartmentHead")
  
  allocations    Allocation[]
  bookings       Booking[]
  maintenanceReq Maintenance[]
  auditsAssigned AuditCycle[] @relation("AuditAuditors")
  
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model Department {
  id             String     @id @default(uuid())
  name           String     @unique
  status         DepartmentStatus @default(Active)
  
  headId         String?    @unique
  head           User?      @relation("DepartmentHead", fields: [headId], references: [id])
  
  parentId       String?
  parent         Department? @relation("SubDepartments", fields: [parentId], references: [id])
  children       Department[] @relation("SubDepartments")
  
  employees      User[]     @relation("EmployeeDepartment")
  allocations    Allocation[]
  
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model AssetCategory {
  id             String     @id @default(uuid())
  name           String     @unique
  customFields   Json?      // To store category-specific fields like warranty period
  assets         Asset[]
  
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model Asset {
  id             String     @id @default(uuid())
  assetTag       String     @unique // e.g., AF-0001
  name           String
  serialNumber   String?    @unique
  acquisitionDate DateTime
  acquisitionCost Float?    
  condition      String
  location       String
  photoUrl       String?
  documentsUrl   String?
  isBookable     Boolean    @default(false)
  status         AssetStatus @default(Available)
  
  categoryId     String
  category       AssetCategory @relation(fields: [categoryId], references: [id])
  
  allocations    Allocation[]
  bookings       Booking[]
  maintenanceReq Maintenance[]
  auditRecords   AuditRecord[]
  
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model Allocation {
  id                 String    @id @default(uuid())
  
  assetId            String
  asset              Asset     @relation(fields: [assetId], references: [id])
  
  userId             String?
  user               User?     @relation(fields: [userId], references: [id])
  
  departmentId       String?
  department         Department? @relation(fields: [departmentId], references: [id])
  
  expectedReturnDate DateTime?
  actualReturnDate   DateTime?
  returnNotes        String?
  isActive           Boolean   @default(true)
  
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model Booking {
  id             String        @id @default(uuid())
  
  assetId        String
  asset          Asset         @relation(fields: [assetId], references: [id])
  
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  
  startTime      DateTime
  endTime        DateTime
  status         BookingStatus @default(Upcoming)
  
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Maintenance {
  id             String            @id @default(uuid())
  
  assetId        String
  asset          Asset             @relation(fields: [assetId], references: [id])
  
  requesterId    String
  requester      User              @relation(fields: [requesterId], references: [id])
  
  description    String
  priority       String            // e.g., Low, Medium, High
  photoUrl       String?
  status         MaintenanceStatus @default(Pending)
  
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model AuditCycle {
  id             String        @id @default(uuid())
  name           String
  startDate      DateTime
  endDate        DateTime
  isClosed       Boolean       @default(false)
  
  auditors       User[]        @relation("AuditAuditors")
  records        AuditRecord[]
  
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model AuditRecord {
  id             String     @id @default(uuid())
  
  auditCycleId   String
  auditCycle     AuditCycle @relation(fields: [auditCycleId], references: [id])
  
  assetId        String
  asset          Asset      @relation(fields: [assetId], references: [id])
  
  status         String     // Verified, Missing, Damaged
  notes          String?
  
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}